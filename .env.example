# RescueNode Zero — Environment Variables
# 
# IMPORTANT: Copy this file to `.env` and fill in your actual keys.
# cp .env.example .env
# VectorAI DB
VECTORAI_HOST=localhost
VECTORAI_PORT=50051

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Models
EMBED_MODEL=all-MiniLM-L6-v2
WHISPER_MODEL=base
CLIP_MODEL=ViT-B-32

# Demo Mode (uses mock data, skips heavy model loading)
DEMO_MODE=true
